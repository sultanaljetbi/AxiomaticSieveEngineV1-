class AxiomaticSieveEngineV1(nn.Module):
    def __init__(self, feature_dim, target_entropy=4.0):
        super().__init__()

        self.feature_dim = feature_dim
        self.target_entropy = target_entropy

        self.calibration_matrix = nn.Parameter(
            torch.eye(feature_dim) + 0.01 * torch.randn(feature_dim, feature_dim)
        )

        self.alpha = nn.Parameter(torch.tensor(0.3))
        self.norm = nn.LayerNorm(feature_dim)

    def compute_entropy(self, x):
        x_norm = (x - x.mean(dim=-1, keepdim=True)) / (x.std(dim=-1, keepdim=True) + 1e-6)
        probs = torch.softmax(x_norm, dim=-1)
        entropy = -torch.sum(probs * torch.log(probs + 1e-9), dim=-1)
        return entropy.mean()

    def forward(self, x):
        entropy = self.compute_entropy(x)

        deficit = torch.relu(self.target_entropy - entropy)
        scale = torch.tanh(deficit)

        mean = torch.mean(x, dim=0, keepdim=True)
        std = torch.std(x, dim=0, keepdim=True) + 1e-6

        deviations = torch.abs(x - mean)
        tail_mask = torch.sigmoid(deviations / std - 1.0)

        # Apply calibration only to tails
        calibrated = torch.matmul(x, self.calibration_matrix)

        reinforced = x + self.alpha * tail_mask * calibrated

        # Soft blend (no if)
        out = x + scale * (reinforced - x)

        return self.norm(out)
